# OpenCut AI Backend — Environment Variables
# Copy this file to .env and update values as needed.
# All variables are prefixed with OPENCUTAI_ (see app/config.py).

# Server
OPENCUTAI_HOST=0.0.0.0
OPENCUTAI_PORT=8420
OPENCUTAI_DEBUG=false

# CORS — origins allowed to call this API (JSON array)
# OPENCUTAI_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Ollama LLM
OPENCUTAI_OLLAMA_URL=http://localhost:11434
OPENCUTAI_OLLAMA_DEFAULT_MODEL=llama3.2
OPENCUTAI_OLLAMA_TIMEOUT=120

# Whisper speech-to-text
# Model sizes: tiny, base, small, medium, large-v3
OPENCUTAI_WHISPER_MODEL_SIZE=base
# Device: auto (uses GPU if available), cpu, cuda
OPENCUTAI_WHISPER_DEVICE=auto
# Compute type: int8, float16, float32
OPENCUTAI_WHISPER_COMPUTE_TYPE=int8

# File paths (defaults to ./generated and ./uploads relative to project root)
# OPENCUTAI_GENERATED_DIR=/app/generated
# OPENCUTAI_UPLOAD_DIR=/app/uploads

# Limits
OPENCUTAI_MAX_UPLOAD_SIZE=524288000  # 500 MB

# Audio analysis
OPENCUTAI_SILENCE_THRESHOLD_DB=-30.0
OPENCUTAI_SILENCE_MIN_DURATION=0.5
OPENCUTAI_DENOISE_STRENGTH=0.7

# Image generation defaults
OPENCUTAI_IMAGE_DEFAULT_WIDTH=512
OPENCUTAI_IMAGE_DEFAULT_HEIGHT=512
OPENCUTAI_IMAGE_DEFAULT_STEPS=20
OPENCUTAI_IMAGE_DEFAULT_GUIDANCE=7.5

# Sarvam AI — Indian language APIs (speech-to-text, translation, TTS)
# Get your key at https://dashboard.sarvam.ai
# Supports 22 Indian regional languages for transcription, translation, and TTS
OPENCUTAI_SARVAM_API_KEY=your_sarvam_api_key_here
# OPENCUTAI_SARVAM_API_BASE_URL=https://api.sarvam.ai
