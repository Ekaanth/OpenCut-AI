# OpenCut AI Backend — Environment Variables
# Copy this file to .env and update values as needed.
# All variables are prefixed with OPENCUT_ (see app/config.py).

# Server
OPENCUT_HOST=0.0.0.0
OPENCUT_PORT=8420
OPENCUT_DEBUG=false

# CORS — origins allowed to call this API (JSON array)
# OPENCUT_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Ollama LLM
OPENCUT_OLLAMA_URL=http://localhost:11434
OPENCUT_OLLAMA_DEFAULT_MODEL=llama3.2
OPENCUT_OLLAMA_TIMEOUT=120

# Whisper speech-to-text
# Model sizes: tiny, base, small, medium, large-v3
OPENCUT_WHISPER_MODEL_SIZE=base
# Device: auto (uses GPU if available), cpu, cuda
OPENCUT_WHISPER_DEVICE=auto
# Compute type: int8, float16, float32
OPENCUT_WHISPER_COMPUTE_TYPE=int8

# File paths (defaults to ./generated and ./uploads relative to project root)
# OPENCUT_GENERATED_DIR=/app/generated
# OPENCUT_UPLOAD_DIR=/app/uploads

# Limits
OPENCUT_MAX_UPLOAD_SIZE=524288000  # 500 MB

# Audio analysis
OPENCUT_SILENCE_THRESHOLD_DB=-30.0
OPENCUT_SILENCE_MIN_DURATION=0.5
OPENCUT_DENOISE_STRENGTH=0.7

# Image generation defaults
OPENCUT_IMAGE_DEFAULT_WIDTH=512
OPENCUT_IMAGE_DEFAULT_HEIGHT=512
OPENCUT_IMAGE_DEFAULT_STEPS=20
OPENCUT_IMAGE_DEFAULT_GUIDANCE=7.5
